{
    "type": "AdvancedStatsPanel", "name": "AdvancedStatsPanel",
    "fields": {
        "rect": { "x": 3, "y": -240, "width": 280, "height": 432 },
        "anchor": "$LeftPanelAnchor",
        "defaultWidget": "ScrollBar",
        "textPadding": 16
    },
    "children": [
        {
            "type": "ImageWidget", "name": "Background",
            "fields": {
                "filename": "PANEL\\AdvancedCharacterSheet\\AdvancedCharacterSheet_BG"
            }
        },
        {
            "type": "ClickCatcherWidget", "name": "ClickCatcher",
            "fields": {
                "rect": {"width": 280, "height": 432 }
            }
        },
        {
            "type": "NineTileImageWidget", "name": "Title",
            "fields": {
                "rect": { "x": 0, "y": 2, "width": 280, "height": 35 },
                "filename": "MENU/boxpieces",
                "tileFrames": "$NineTileBoxPiecesFrames",
                "backgroundColor": [ 0.0, 0.0, 0.0, 0.8 ]
            },
            "children": [
                {
                    "type": "TextBoxWidget", "name": "Title",
                    "fields": {
                        "fitToParent": true,
                        "text": "@AdvancedStats",
                        "style": {
                            //"fontColor": { "r": 199, "g": 179, "b": 119, "a": 255 },
                            "alignment": { "h": "center", "v": "center" },
                            "options": { "pipeCharacterBehavior" : "handle", "newlineHandling": "standard" }
                        }
                    }
                },
            ]
        },
        {
            "type": "NineTileImageWidget", "name": "AdvancedStatsContainer",
            "fields": {
                "rect": { "x": 0, "y": 35, "width": 280, "height": 396 },
                "filename": "MENU/boxpieces",
                "tileFrames": "$NineTileBoxPiecesFrames",
                "backgroundColor": [ 0.0, 0.0, 0.0, 0.8 ]
            },
        },
		{
			"type": "NineTileImageWidget", "name": "ScrollBarBackground",
			"fields": {
				"rect": { "x": 272, "y": 48, "width": 12, "height": 364 },
				"filename": "MENU/slider_background",
				"tileFrames": "$NineTileNoFrames",
				"tileFrames": { "center": 0 }
			},
		},
        {
            "type": "ScrollControllerWidget", "name": "ScrollBar",
            "fields": {
                "rect": { "x": 272, "y": 48, "width": 12, "height": 368 },
                "upArrowFilepath": "MENU/slider_up_button",
                "downArrowFilepath": "MENU/slider_down_button",
                "barFilepath": "MENU/slider_bar",
                "viewName": "ListContainer",
            }
        },
        {
            "type": "ListWidget", "name": "ListContainer",
            "fields": {
                "rect": { "x": 20, "y": 30, "width": 280, "height": 390},
                "direction": "vertical",
                "scrollControllerName": "ScrollBar",
            },
            "children": [
                {
                    "type": "ListItemWidget", "name": "OptionTemplate",
                    "fields": {
                        "rect": { "x": 0, "y": 10, "width": 280 } //, "height": 5
                    },
                    "children": [
                        {
                          "type": "TextBoxWidget", "name": "StatText",
                            "fields": {
                                "rect": { "x": 0, "y": 0, "width": 280 }, //, "height": 5
                                "style": {
                                    "fontColor": "$FontColorWhite",
                                    "pointSize": 16,
                                    "alignment": { "h": "left", "v": "center" },
                                    "options": {
                                        "lineWrap": true,
                                        "pipeCharacterBehavior": "handle",
                                    },
                                }
                            }
                        },
                    ]
                }
            ]
        }
    ]
}
